<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main App Theme (status bar visible, white background, gold accent) -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#D4A853</item>
        <item name="colorPrimaryDark">#B8902E</item>
        <item name="colorAccent">#D4A853</item>
        <item name="android:windowBackground">#FFFFFF</item>
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:fitsSystemWindows">false</item>
    </style>

    <!-- NoActionBar variant used by MainActivity -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#D4A853</item>
        <item name="colorPrimaryDark">#B8902E</item>
        <item name="colorAccent">#D4A853</item>
        <item name="android:windowBackground">#FFFFFF</item>
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:fitsSystemWindows">false</item>
    </style>

    <!--
        Launch theme - replaces the old full-screen splash image.
        Uses a plain white background (no splash.png overlay, no big logo).
        This eliminates the "big splash screen" the user complained about.
        windowIsTranslucent is removed so the WebView is laid out BELOW the
        status bar by default (the web layer uses env(safe-area-inset-top)).
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="AppTheme.NoActionBar">
        <item name="android:windowBackground">#FFFFFF</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
